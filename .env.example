# ============================================
# Azure OpenAI — LLM (Responses API)
# ============================================
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://users-direct-oai.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=o4-mini

# ============================================
# Azure OpenAI — Embeddings
# ============================================
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=uniko-poc-embeddings
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview

# ============================================
# LangSmith — Observability & Tracing
# ============================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=nbg-banking-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================
# RAG — Chunking & Retrieval
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# ============================================
# Crawling — Target URLs & Settings
# ============================================
NBG_BASE_URL=https://www.nbg.gr
# Offline: pre-crawled with Crawl4AI, chunked and stored in ChromaDB (static product/service pages)
NBG_CRAWL_URLS=["https://www.nbg.gr/en/individuals","https://www.nbg.gr/en/individuals/daily-transactions/banking-accounts","https://www.nbg.gr/en/individuals/daily-transactions/banking-accounts/benefits-account","https://www.nbg.gr/en/individuals/daily-transactions/banking-accounts/everyday-accounts/savings-account","https://www.nbg.gr/en/individuals/daily-transactions/banking-accounts/everyday-accounts/current-account","https://www.nbg.gr/en/individuals/daily-transactions/banking-accounts/salary-pension-accounts","https://www.nbg.gr/en/individuals/daily-transactions/cards/credit-cards","https://www.nbg.gr/en/individuals/daily-transactions/cards/credit-cards/gold","https://www.nbg.gr/en/individuals/daily-transactions/cards/credit-cards/silver","https://www.nbg.gr/en/individuals/daily-transactions/cards/debit-cards","https://www.nbg.gr/en/individuals/daily-transactions/cards/prepaid-cards","https://www.nbg.gr/en/individuals/loans/mortgages","https://www.nbg.gr/en/individuals/loans/personal-loans","https://www.nbg.gr/en/individuals/loans/personal-loans/express","https://www.nbg.gr/en/individuals/loans/mortgages/property-loans/estia-green","https://www.nbg.gr/en/individuals/loans/energy-efficiency-loans","https://www.nbg.gr/en/individuals/loans/student-loans","https://www.nbg.gr/en/business","https://www.nbg.gr/en/go4more/how-go4more-works","https://www.nbg.gr/en/individuals/daily-transactions/cards/installment-selection-program"]
# Live: scraped on-demand by the agent via httpx + BeautifulSoup (frequently updated pages)
NBG_SCRAPE_URLS=["https://www.nbg.gr/en/go4more","https://www.nbg.gr/en/go4more/offers","https://www.nbg.gr/en/go4more/partners","https://www.nbg.gr/en/group/press-office","https://www.nbg.gr/en/group/press-office/articles/r-17-03-26-etalia-b-closing-en","https://www.nbg.gr/en/group/press-office/articles/r-27-02-26-fy25-financial-results-en","https://www.nbg.gr/en/group/press-office/articles/r-06-02-26-at1-issuance-500mn-en","https://www.nbg.gr/en/group/press-office/articles/r-26-01-26-green-bonds-eng","https://www.nbg.gr/en/individuals/daily-transactions/cards/credit-cards/skroutz-plus-mastercard","https://www.nbg.gr/en/individuals/daily-transactions/cards/dual-card","https://www.nbg.gr/en/individuals/daily-transactions/find-the-right-card","https://www.nbg.gr/en/individuals/loans/find-your-mortgage-loan","https://www.nbg.gr/en/individuals/loans/find-your-personal-loan","https://www.nbg.gr/en/individuals/loans/mortgages/my-home-ii-state-housing-program","https://www.nbg.gr/en/individuals/loans/mortgages/repair-renovation-loans/upgrade-my-home","https://www.nbg.gr/en/individuals/daily-transactions/reward-packages/plus-benefits-account","https://www.nbg.gr/en/individuals/daily-transactions/reward-packages/benefits-salary-account","https://www.nbg.gr/en/retail","https://www.nbg.gr/en/individuals/daily-transactions/digital-banking","https://www.nbg.gr/en/contact"]
CRAWL_RATE_LIMIT=1.0
CRAWL_MAX_DEPTH=2
CRAWL_TIMEOUT=30
CRAWL_ALLOWED_DOMAIN=nbg.gr

# ============================================
# Paths — Data & Storage
# ============================================
DATA_DIR=data
VECTOR_STORE_PATH=data/vector_store
